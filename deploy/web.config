<?xml version="1.0" encoding="utf-8"?>
<!--
  Plantilla de web.config para el Sistema Integrado HITSS en IIS.

  El script publicar-iis.bat GENERA este archivo en la carpeta de publicación
  con las rutas reales. Esta copia sirve de referencia: reemplaza __PUBLISH_DIR__
  por la ruta de publicación (p. ej. E:\IIS_PRD\Sistema_Integrado).

  Requiere el módulo HttpPlatformHandler instalado en IIS.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*"
           modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>

    <!-- Lanza Uvicorn (FastAPI). IIS asigna el puerto en %HTTP_PLATFORM_PORT%. -->
    <httpPlatform processPath="__PUBLISH_DIR__\api\.venv\Scripts\python.exe"
                  arguments="-m uvicorn app.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile="__PUBLISH_DIR__\logs\stdout"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="APP_ROOT_PATH" value="/SistemaIntegrado" />
        <environmentVariable name="PYTHONPATH" value="__PUBLISH_DIR__\api" />
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>

    <!-- Defensa en profundidad: bloquear archivos/segmentos sensibles. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
        <hiddenSegments>
          <add segment=".venv" />
          <add segment="logs" />
          <add segment=".git" />
        </hiddenSegments>
        <fileExtensions allowUnlisted="true">
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".py" allowed="false" />
          <add fileExtension=".bat" allowed="false" />
          <add fileExtension=".toml" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <directoryBrowse enabled="false" />
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
